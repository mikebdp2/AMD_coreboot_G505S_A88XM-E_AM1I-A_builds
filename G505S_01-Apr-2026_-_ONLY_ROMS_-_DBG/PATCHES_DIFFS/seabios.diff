From ca60998eefc15ad94fac1993eb34410ab188dad8 Mon Sep 17 00:00:00 2001
From: Mike Banon <mikebdp2@gmail.com>
Date: Fri, 20 Mar 2026 04:16:58 +0300
Subject: [PATCH] payloads/seabios: Apply patches for multiple large ramdisks, 2-page menu, numpad

Apply a comprehensive series of patches to SeaBIOS that significantly
enhance boot capabilities, user interaction, and hardware support.
These changes are particularly useful for coreboot users who want to:

- Boot from multiple floppy/ramdisk images (up to 63MB!) stored in CBFS
  without re-flashing ROM - to use multiple OS like KolibriOS, FreeDOS,
  MichalOS, Visopsys, Snowdrop, Fiwix and my Floppinux-AMD64net distro:
      https://github.com/mikebdp2/floppinux-amd64net
- Accommodate platforms with larger SMBIOS/MPTABLE sizes (e.g., Lenovo
  G505S, ASUS A88XM-E, ASUS AM1I-A) and optimize the F-segment usage.
- Navigate large boot lists efficiently using a USB numpad with editing,
  "scrolling" (by a plus or minus keys) and input confirmation features.

The patches are applied in numerical order after checkout and before
configuration to ensure a consistent build.

Patches included:
 1. scripts: Increase BUILD_MIN_BIOSTABLE for auto-sized and 128KB ROMs
 2. config: Increase BUILD_MAX_EXTDRIVE from 16 to 36
 3. config: Raise MPTABLE and SMBIOS F-segment size limits from 600 to 768
 4. config: Increase BUILD_MAX_HIGHTABLE from 16MB to 80MB for large ramdisk support
 5. block: Move IDMap from VARFSEG to VARLOW to save F-segment space
 6. floppy: Add floppy_get_chs() and floppy_get_data_rate() helper functions
 7. boot: Replace hardcoded BEV array size with BUILD_MAX_EXTDRIVE * 3
 8. boot: Move BEV array to VARLOW for explicit low-memory placement
 9. boot, ramdisk: Multiple ramdisk precise support with F-segment conservation
10. boot: Reorganize boot menu keyboard layout to QWERTY order with TPM on m key
11. boot: Add paging support for boot menu to prevent scroll overflow
12. boot: Add advanced numpad input and dual-function Enter key support
13. boot: Increase menu timeout and ESC delay for slow-display compatibility

Signed-off-by: Mike Banon <mikebdp2@gmail.com>
Change-Id: Iff9c2760376ac1bff18c9cfcf9e8a8eef0cbeba3
---

diff --git a/payloads/external/SeaBIOS/0001-scripts-Increase-BUILD_MIN_BIOSTABLE-for-auto-sized-and-128KB-ROMs.patch b/payloads/external/SeaBIOS/0001-scripts-Increase-BUILD_MIN_BIOSTABLE-for-auto-sized-and-128KB-ROMs.patch
new file mode 100644
index 0000000..26c6196
--- /dev/null
+++ b/payloads/external/SeaBIOS/0001-scripts-Increase-BUILD_MIN_BIOSTABLE-for-auto-sized-and-128KB-ROMs.patch
@@ -0,0 +1,63 @@
+scripts: Increase BUILD_MIN_BIOSTABLE for auto-sized and 128KB ROMs
+
+When CONFIG_ROM_SIZE is left at 0 (auto), checkrom.py will automatically
+determine the ROM size based on the actual binary size (up to 256KB).
+However, layoutrom.py only increased BUILD_MIN_BIOSTABLE to 8192 when
+CONFIG_ROM_SIZE was explicitly set to 256 or larger. This meant that if
+the code grew large enough to require a 256KB ROM, layoutrom.py would
+still use the smaller 2048-byte F-segment reserve, potentially causing
+resource allocation problems in case of a big number of boot entries.
+Also, 128KB ROMs should have a larger 4096-byte F-segment reserve.
+
+Fix this erroneous behavior for non-specified CONFIG_ROM_SIZE case by
+calculating the total raw size of all sections that will be placed in
+the ROM. This raw sum underestimates the final binary size by roughly
+5% due to alignment padding and relocation tables, so if it exceeds
+64KB we can reliably conclude the final ROM will be at least 128KB and
+set BUILD_MIN_BIOSTABLE = 4096; if it exceeds 128KB the final ROM will
+be 256KB and we set BUILD_MIN_BIOSTABLE = 8192, matching the behavior
+for explicitly configured 128KB and 256KB ROMs.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ scripts/layoutrom.py | 18 ++++++++++++++----
+ 1 file changed, 14 insertions(+), 4 deletions(-)
+
+diff --git a/scripts/layoutrom.py b/scripts/layoutrom.py
+index abebf021..4fe75ceb 100755
+--- a/scripts/layoutrom.py
++++ b/scripts/layoutrom.py
+@@ -651,10 +651,6 @@ def main():
+     # Read kconfig config file
+     config = scanconfig(cfgfile)
+ 
+-    # larger roms have more room in the f-segment due to moving out 32bit code
+-    if config.get('CONFIG_ROM_SIZE') >= 256:
+-        BUILD_MIN_BIOSTABLE = 8192
+-
+     # Figure out which sections to keep.
+     allsections = info16[0] + info32seg[0] + info32flat[0]
+     symbols = {'16': info16[1], '32seg': info32seg[1], '32flat': info32flat[1]}
+@@ -670,6 +666,20 @@ def main():
+     keepsections = findReachable(anchorsections, checkKeep, symbols)
+     sections = [section for section in allsections if section in keepsections]
+ 
++    # larger roms have more room in the f-segment due to moving out 32bit code
++    if config.get('CONFIG_ROM_SIZE') >= 128:
++        BUILD_MIN_BIOSTABLE = 4096
++    if config.get('CONFIG_ROM_SIZE') >= 256:
++        BUILD_MIN_BIOSTABLE = 8192
++    if config.get('CONFIG_ROM_SIZE') == 0:
++        sections_size = 0
++        for section in sections:
++            sections_size += section.size
++        if sections_size >  64 * 1024:
++            BUILD_MIN_BIOSTABLE = 4096
++        if sections_size > 128 * 1024:
++            BUILD_MIN_BIOSTABLE = 8192
++
+     # Separate 32bit flat into runtime, init, and special variable parts
+     anchorsections = [
+         section for section in sections
+-- 
+2.53.0
diff --git a/payloads/external/SeaBIOS/0002-config-Increase-BUILD_MAX_EXTDRIVE-from-16-to-36.patch b/payloads/external/SeaBIOS/0002-config-Increase-BUILD_MAX_EXTDRIVE-from-16-to-36.patch
new file mode 100644
index 0000000..d68f4da
--- /dev/null
+++ b/payloads/external/SeaBIOS/0002-config-Increase-BUILD_MAX_EXTDRIVE-from-16-to-36.patch
@@ -0,0 +1,27 @@
+config: Increase BUILD_MAX_EXTDRIVE from 16 to 36
+
+Raise the maximum number of drives per type (floppy, hard disk, CD-ROM) to 36.
+This provides additional headroom for systems with many drives, such as multiple
+hard disks, CD-ROMs, or virtual floppies. All arrays dimensioned by
+BUILD_MAX_EXTDRIVE expand accordingly, consuming negligible additional memory.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/config.h | 2 +-
+ 1 file changed, 1 insertion(+), 1 deletion(-)
+
+diff --git a/src/config.h b/src/config.h
+index 16952eb7..5700450a 100644
+--- a/src/config.h
++++ b/src/config.h
+@@ -20,7 +20,7 @@
+ #define BUILD_MIN_HIGHTABLE (256*1024)
+ #define BUILD_MAX_HIGHTABLE (16*1024*1024)
+ // Largest supported externaly facing drive id
+-#define BUILD_MAX_EXTDRIVE 16
++#define BUILD_MAX_EXTDRIVE 36
+ // Number of bytes the smbios may be and still live in the f-segment
+ #define BUILD_MAX_SMBIOS_FSEG     600
+ // Maximum number of bytes the mptable may be and still be copied to f-segment
+-- 
+2.53.0
diff --git a/payloads/external/SeaBIOS/0003-config-Raise-MPTABLE-and-SMBIOS-F-segment-size-limits-from-600-to-768.patch b/payloads/external/SeaBIOS/0003-config-Raise-MPTABLE-and-SMBIOS-F-segment-size-limits-from-600-to-768.patch
new file mode 100644
index 0000000..6517cb8
--- /dev/null
+++ b/payloads/external/SeaBIOS/0003-config-Raise-MPTABLE-and-SMBIOS-F-segment-size-limits-from-600-to-768.patch
@@ -0,0 +1,31 @@
+config: Raise MPTABLE and SMBIOS F-segment size limits from 600 to 768
+
+The current 600-byte limit for copying MPTABLE and SMBIOS tables to the
+F-segment is arbitrary and not aligned with power-of-two sizes. Some platforms
+require slightly larger tables (up to ~740 bytes), causing them to be truncated.
+Increase the limit to 768 bytes, a rounder value that provides ample headroom
+while remaining within the F-segment space. Adjust both limits for consistency.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/config.h | 4 ++--
+ 1 file changed, 2 insertions(+), 2 deletions(-)
+
+diff --git a/src/config.h b/src/config.h
+index 5700450a..7d98ed8b 100644
+--- a/src/config.h
++++ b/src/config.h
+@@ -22,9 +22,9 @@
+ // Largest supported externaly facing drive id
+ #define BUILD_MAX_EXTDRIVE 36
+ // Number of bytes the smbios may be and still live in the f-segment
+-#define BUILD_MAX_SMBIOS_FSEG     600
++#define BUILD_MAX_SMBIOS_FSEG     768
+ // Maximum number of bytes the mptable may be and still be copied to f-segment
+-#define BUILD_MAX_MPTABLE_FSEG    600
++#define BUILD_MAX_MPTABLE_FSEG    768
+ 
+ #define BUILD_MODEL_ID      0xFC
+ #define BUILD_SUBMODEL_ID   0x00
+--
+2.53.0
diff --git a/payloads/external/SeaBIOS/0004-config-Increase-BUILD_MAX_HIGHTABLE-from-16MB-to-80M-for-large-ramdisk-support.patch b/payloads/external/SeaBIOS/0004-config-Increase-BUILD_MAX_HIGHTABLE-from-16MB-to-80M-for-large-ramdisk-support.patch
new file mode 100644
index 0000000..7614a3f
--- /dev/null
+++ b/payloads/external/SeaBIOS/0004-config-Increase-BUILD_MAX_HIGHTABLE-from-16MB-to-80M-for-large-ramdisk-support.patch
@@ -0,0 +1,34 @@
+config: Increase BUILD_MAX_HIGHTABLE from 16MB to 80MB for large ramdisk support
+
+The BUILD_MAX_HIGHTABLE constant defines the maximum space that can be reserved
+in high-memory (ZoneHigh) for runtime tables and buffers. The current 16MB limit
+is sufficient for standard SeaBIOS operation but is inadequate to support
+custom-sized ramdisks as large as 63MB, the code for which is being added.
+
+A single ramdisk can be as large as 63 MB (2 heads * 1024 cylinders * 63 sectors
+per track * 512 bytes sector size). The ramdisk shared buffer must be allocated
+in ZoneHigh to persist across the boot process. Only one ramdisk is loaded at a
+time, its buffer must accommodate the full image. Raising BUILD_MAX_HIGHTABLE to
+80MB provides headroom for a 63MB ramdisk plus additional runtime allocations,
+while remaining well within typical system RAM limits on modern hardware.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/config.h | 2 +-
+ 1 file changed, 1 insertion(+), 1 deletion(-)
+
+diff --git a/src/config.h b/src/config.h
+index 5700450a..91370684 100644
+--- a/src/config.h
++++ b/src/config.h
+@@ -18,7 +18,7 @@
+ #define BUILD_MAX_E820 128
+ // Space to reserve in high-memory for tables
+ #define BUILD_MIN_HIGHTABLE (256*1024)
+-#define BUILD_MAX_HIGHTABLE (16*1024*1024)
++#define BUILD_MAX_HIGHTABLE (80*1024*1024)
+ // Largest supported externaly facing drive id
+ #define BUILD_MAX_EXTDRIVE 36
+ // Number of bytes the smbios may be and still live in the f-segment
+-- 
+2.53.0
diff --git a/payloads/external/SeaBIOS/0005-block-Move-IDMap-from-VARFSEG-to-VARLOW-to-save-F-segment-space.patch b/payloads/external/SeaBIOS/0005-block-Move-IDMap-from-VARFSEG-to-VARLOW-to-save-F-segment-space.patch
new file mode 100644
index 0000000..cf9d5102
--- /dev/null
+++ b/payloads/external/SeaBIOS/0005-block-Move-IDMap-from-VARFSEG-to-VARLOW-to-save-F-segment-space.patch
@@ -0,0 +1,74 @@
+block: Move IDMap from VARFSEG to VARLOW to save F-segment space
+
+The F-segment (64KB) is a precious, limited resource in SeaBIOS that must
+accommodate the BIOS runtime code, option ROMs (VGA, NIC, HBA), ACPI tables,
+SMBIOS tables, and PnP BIOS structures. The IDMap array stores drive pointers
+for floppy, hard disk, and CD-ROM types. At BUILD_MAX_EXTDRIVE=36, this array
+consumes 432 bytes (3*36*4). Moving it from VARFSEG to VARLOW frees up
+F-segment space for these critical consumers while maintaining correct
+functionality from all execution contexts (real mode, protected mode, SMM).
+
+This change replaces GET_GLOBAL() with GET_LOW() for IDMap access and adds the
+BUILD_MAX_EXTDRIVE include to block.h. The IDMap structure is now exposed
+externally via extern declaration in block.h, enabling other modules like
+ramdisk.c to access drive mappings directly.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/block.c | 6 +++---
+ src/block.h | 2 ++
+ 2 files changed, 5 insertions(+), 3 deletions(-)
+
+diff --git a/src/block.c b/src/block.c
+index 1f600b85..22d3953d 100644
+--- a/src/block.c
++++ b/src/block.c
+@@ -5,7 +5,7 @@
+ //
+ // This file may be distributed under the terms of the GNU LGPLv3 license.
+ 
+-#include "biosvar.h" // GET_GLOBAL
++#include "biosvar.h" // GET_GLOBALFLAT
+ #include "block.h" // process_op
+ #include "hw/ata.h" // process_ata_op
+ #include "hw/ahci.h" // process_ahci_op
+@@ -30,7 +30,7 @@
+ 
+ u8 FloppyCount VARFSEG;
+ u8 CDCount;
+-struct drive_s *IDMap[3][BUILD_MAX_EXTDRIVE] VARFSEG;
++struct drive_s *IDMap[3][BUILD_MAX_EXTDRIVE] VARLOW;
+ u8 *bounce_buf_fl VARFSEG;
+ 
+ struct drive_s *
+@@ -38,7 +38,7 @@ getDrive(u8 exttype, u8 extdriveoffset)
+ {
+     if (extdriveoffset >= ARRAY_SIZE(IDMap[0]))
+         return NULL;
+-    return GET_GLOBAL(IDMap[exttype][extdriveoffset]);
++    return GET_LOW(IDMap[exttype][extdriveoffset]);
+ }
+ 
+ int getDriveId(u8 exttype, struct drive_s *drive)
+diff --git a/src/block.h b/src/block.h
+index 3af2d716..3dc3db66 100644
+--- a/src/block.h
++++ b/src/block.h
+@@ -2,6 +2,7 @@
+ #define __BLOCK_H
+ 
+ #include "types.h" // u32
++#include "config.h" // BUILD_MAX_EXTDRIVE
+ 
+ 
+ /****************************************************************
+@@ -108,6 +109,7 @@ struct drive_s {
+ 
+ // block.c
+ extern u8 FloppyCount, CDCount;
++extern struct drive_s *IDMap[3][BUILD_MAX_EXTDRIVE];
+ extern u8 *bounce_buf_fl;
+ struct drive_s *getDrive(u8 exttype, u8 extdriveoffset);
+ int getDriveId(u8 exttype, struct drive_s *drive);
+-- 
+2.53.0
diff --git a/payloads/external/SeaBIOS/0006-floppy-Add-floppy_get_chs-and-floppy_get_data_rate-helper-functions.patch b/payloads/external/SeaBIOS/0006-floppy-Add-floppy_get_chs-and-floppy_get_data_rate-helper-functions.patch
new file mode 100644
index 0000000..f7e1f43
--- /dev/null
+++ b/payloads/external/SeaBIOS/0006-floppy-Add-floppy_get_chs-and-floppy_get_data_rate-helper-functions.patch
@@ -0,0 +1,63 @@
+floppy: Add floppy_get_chs() and floppy_get_data_rate() helper functions
+
+The FloppyInfo[] array contains authoritative CHS geometry and FDC data rate
+information for standard floppy types. Previously, this data was only accessible
+internally within floppy.c. These new helper functions will provide the safe
+read-only access to FloppyInfo[] - in particular, ramdisk.c will need this data
+for the upcoming significant improvement of its ramdisk emulation feature.
+
+This ensures a single source of truth for floppy geometry and data rates, allows
+future code to match SeaBIOS's native floppy behavior and prevents out-of-bounds
+access to the FloppyInfo[] array by validating the ftype parameter.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/hw/floppy.c | 19 +++++++++++++++++++
+ src/util.h      |  2 ++
+ 2 files changed, 21 insertions(+)
+
+diff --git a/src/hw/floppy.c b/src/hw/floppy.c
+index 9e6647d4..2668ac91 100644
+--- a/src/hw/floppy.c
++++ b/src/hw/floppy.c
+@@ -186,6 +186,25 @@ find_floppy_type(u32 size)
+     return -1;
+ }
+ 
++// Get CHS geometry for a floppy type.
++int
++floppy_get_chs(int ftype, struct chs_s *chs)
++{
++    if (ftype <= 0 || ftype >= ARRAY_SIZE(FloppyInfo))
++        return -1;
++    *chs = FloppyInfo[ftype].chs;
++    return 0;
++}
++
++// Get FDC data rate for a floppy type.
++int
++floppy_get_data_rate(int ftype)
++{
++    if (ftype <= 0 || ftype >= ARRAY_SIZE(FloppyInfo))
++        return -1;
++
++    return FloppyInfo[ftype].data_rate;
++}
+ 
+ /****************************************************************
+  * Low-level floppy IO
+diff --git a/src/util.h b/src/util.h
+index aff8e888..6679b0ae 100644
+--- a/src/util.h
++++ b/src/util.h
+@@ -169,6 +169,8 @@ extern struct floppy_ext_dbt_s diskette_param_table2;
+ void floppy_setup(void);
+ struct drive_s *init_floppy(int floppyid, int ftype);
+ int find_floppy_type(u32 size);
++int floppy_get_chs(int ftype, struct chs_s *chs);
++int floppy_get_data_rate(int ftype);
+ int floppy_process_op(struct disk_op_s *op);
+ void floppy_tick(void);
+ 
+-- 
+2.53.0
diff --git a/payloads/external/SeaBIOS/0007-boot-Replace-hardcoded-BEV-array-size-with-BUILD_MAX_EXTDRIVE-3.patch b/payloads/external/SeaBIOS/0007-boot-Replace-hardcoded-BEV-array-size-with-BUILD_MAX_EXTDRIVE-3.patch
new file mode 100644
index 0000000..1ff99a4
--- /dev/null
+++ b/payloads/external/SeaBIOS/0007-boot-Replace-hardcoded-BEV-array-size-with-BUILD_MAX_EXTDRIVE-3.patch
@@ -0,0 +1,32 @@
+boot: Replace hardcoded BEV array size with BUILD_MAX_EXTDRIVE * 3
+
+The BEV array stores boot entries for floppy, HDD and CDROM drives, as well as
+option ROMs and other boot sources. The previous hardcoded limit of 20 entries
+was arbitrary and could be exceeded when many drives are present - especially
+with the upcoming support for multiple floppies and ramdisk images.
+
+The max number of drive boot entries is bounded by BUILD_MAX_EXTDRIVE per drive
+type. Since there are three drive types, the worst-case drive-only total is
+BUILD_MAX_EXTDRIVE * 3. Using this value ensures that the array cannot overflow
+due to the drives, while still leaving enough room for the option ROM entries.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/boot.c | 2 +-
+ 1 file changed, 1 insertion(+), 1 deletion(-)
+
+diff --git a/src/boot.c b/src/boot.c
+index 5c37dafd..18e62a43 100644
+--- a/src/boot.c
++++ b/src/boot.c
+@@ -798,7 +798,7 @@ struct bev_s {
+     int type;
+     u32 vector;
+ };
+-static struct bev_s BEV[20];
++static struct bev_s BEV[BUILD_MAX_EXTDRIVE * 3];
+ static int BEVCount;
+ static int HaveHDBoot, HaveFDBoot;
+ 
+-- 
+2.53.0
diff --git a/payloads/external/SeaBIOS/0008-boot-Move-BEV-array-to-VARLOW-for-explicit-low-memory-placement.patch b/payloads/external/SeaBIOS/0008-boot-Move-BEV-array-to-VARLOW-for-explicit-low-memory-placement.patch
new file mode 100644
index 0000000..7d6de8c
--- /dev/null
+++ b/payloads/external/SeaBIOS/0008-boot-Move-BEV-array-to-VARLOW-for-explicit-low-memory-placement.patch
@@ -0,0 +1,32 @@
+boot: Move BEV array to VARLOW for explicit low-memory placement
+
+The BEV (Boot Execution Vector) array stores boot entries for floppy, hard disk,
+and CD-ROM types. At BUILD_MAX_EXTDRIVE=36, this array consumes 864 bytes
+(36*3*8). Moving it to VARLOW ensures explicit low-memory placement, making it
+accessible from all execution contexts (real mode, protected mode, SMM) while
+avoiding potential F-segment space consumption.
+
+This change removes the static qualifier from the BEV array and adds VARLOW,
+making it externally visible for access from other modules. This prepares the
+code for the upcoming significant improvement of its ramdisk emulation feature.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/boot.c | 2 +-
+ 1 file changed, 1 insertion(+), 1 deletion(-)
+
+diff --git a/src/boot.c b/src/boot.c
+index 18e62a43..65092eba 100644
+--- a/src/boot.c
++++ b/src/boot.c
+@@ -798,7 +798,7 @@ struct bev_s {
+     int type;
+     u32 vector;
+ };
+-static struct bev_s BEV[BUILD_MAX_EXTDRIVE * 3];
++struct bev_s BEV[BUILD_MAX_EXTDRIVE * 3] VARLOW;
+ static int BEVCount;
+ static int HaveHDBoot, HaveFDBoot;
+ 
+-- 
+2.53.0
diff --git a/payloads/external/SeaBIOS/0009-boot-ramdisk-Multiple-ramdisk-precise-support-with-F-segment-conservation.patch b/payloads/external/SeaBIOS/0009-boot-ramdisk-Multiple-ramdisk-precise-support-with-F-segment-conservation.patch
new file mode 100644
index 0000000..2c7faf5
--- /dev/null
+++ b/payloads/external/SeaBIOS/0009-boot-ramdisk-Multiple-ramdisk-precise-support-with-F-segment-conservation.patch
@@ -0,0 +1,1112 @@
+boot, ramdisk: Multiple ramdisk precise support with F-segment conservation
+
+Extend ramdisk support to handle multiple images with full boot menu
+integration. Ramdisks and "BootList devices" (physical devices and secondary
+payloads) appear in a merged boot menu, sorted by bootorder priority. Ramdisks
+boot directly before PMM finalize, with automatic fallback to the next entry on
+failure. Meanwhile, the "BootList devices" hand off to the standard BEV flow.
+
+CRITICAL: Ramdisks use a separate pool (ramdisk_pool[]) rather than adding to
+BootList like BEV/BCV entries. This avoids F-segment exhaustion that would occur
+if each ramdisk allocated a separate drive_s structure in VARFSEG. Instead, a
+single shared buffer in ZoneHigh holds the selected image, while pool metadata
+resides in VARLOW. This design scales to multiple ramdisks without consuming
+precious F-segment space needed for option ROMs and ACPI / SMBIOS tables.
+
+To support this:
+- Add ramdisk_pool[] in VARLOW to store multiple ramdisk entries
+- Implement prepare_bootmenu() to merge ramdisks and BootList entries
+- Add apply_boot_selection() for unified boot selection handling
+- Move BEV[] and BootSequence to VARLOW to conserve F-segment space
+- Save/restore complete BDA state (media_state, motor_counter, DPT)
+- Set FDC data rate via PORT_FD_DIR and floppy_media_state BDA field
+- Support dual prefixes: "ramdisk/" and "floppyimg/" for backward compat
+- Defer bootorder name matching until after ramdisk pool initialization
+- Export boot_disk() for ramdisk.c to call directly
+
+This enables hobby OS developers/enthusiasts to test and use multiple floppies
+and ramdisk images from a single coreboot+SeaBIOS build without ROM reflashings,
+with bootorder control over ramdisk versus physical device / secondary payload
+priority. The implementation matches SeaBIOS floppy behavior, ensuring a better
+compatibility with OSes that expect standard floppy geometry and FDC config.
+
+Signed-off-by: Mike Banon <mikebdp2@gmail.com>
+---
+ src/boot.c       | 394 +++++++++++++++++++++++++++++++------
+ src/hw/ramdisk.c | 500 ++++++++++++++++++++++++++++++++++++++++++++---
+ src/util.h       |   6 +
+ 3 files changed, 813 insertions(+), 87 deletions(-)
+
+diff --git a/src/boot.c b/src/boot.c
+index 65092eba..8ebf5edc 100644
+--- a/src/boot.c
++++ b/src/boot.c
+@@ -245,6 +245,36 @@ int boot_lchs_find_ata_device(struct pci_device *pci, int chanid, int slave,
+ static char **Bootorder VARVERIFY32INIT;
+ static int BootorderCount;
+ 
++#define FLOPPYIMG_BOOTORDER_PREFIX "/rom@floppyimg/"
++#define RAMDISK_BOOTORDER_PREFIX "/rom@ramdisk/"
++
++struct ramdisk_bootorder_entry {
++    const char *name;
++    int priority;
++};
++
++struct menu_entry {
++    u8 is_ramdisk;
++    union {
++        int ramdisk_pool_index;
++        struct bootentry_s *bootlist_entry;
++    };
++    int priority;
++};
++
++struct ramdisk_bootorder_entry *ramdisk_bootorder_list VARLOW;
++int ramdisk_bootorder_count VARLOW;
++
++static void
++free_ramdisk_bootorder_list(void)
++{
