++        ftype = 0xFF;
++        if (chs_size != native_size)
++            dprintf(1, "%s: will be 0-padded from %u to %u bytes, ftype=%d\n",
++                    entry->file->name, native_size, chs_size, ftype);
++    }
++
++    entry->size  = chs_size;
++    entry->ftype = ftype;
++}
