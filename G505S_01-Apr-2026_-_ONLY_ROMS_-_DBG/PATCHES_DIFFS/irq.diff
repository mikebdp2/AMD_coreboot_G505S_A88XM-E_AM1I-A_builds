From 039f67d8bb34eb4bdfe904c19a12e7450fdcce0d Mon Sep 17 00:00:00 2001
From: Mike Banon <mikebdp2@gmail.com>
Date: Mon, 07 Dec 2020 07:27:40 +0300
Subject: [PATCH] AMD good IRQs: scripts for applying the unofficial (not-merged-yet) patches

These scripts will help you to securely and conveniently apply
ten changes for improving the IRQ routing on these AMD boards:
1) CB:58750, CB:58751, CB:58752, CB:58753 - for AMD Lenovo G505S;
2) CB:48424, CB:48425, CB:48426 - for ASUS A88XM-E;
3) CB:58754, CB:58755, CB:58756 - for ASUS AM1I-A.
Save to ./coreboot/ then run ./get_irq_patches.sh , ./check... and ./apply...

Change-Id: I04869ae24185eef5399c3fd9b8d4965ec4e33a19
---

diff --git a/apply_irq_patches.sh b/apply_irq_patches.sh
new file mode 100755
index 0000000..cf7960e
--- /dev/null
+++ b/apply_irq_patches.sh
@@ -0,0 +1,52 @@
+#!/bin/sh
+###
+### https://review.coreboot.org/c/coreboot/+/58750
+### lenovo/g505s: fix the IRQs and create the good MP tables
+###
+patch -p1 < "./8c78f54.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/58751
+### lenovo/g505s: update the ACPI routing to match the new IRQ routing
+###
+patch -p1 < "./f0db861.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/58752
+### lenovo/g505s: add the PIRQ routing table
+###
+patch -p1 < "./8aa0ae3.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/58753
+### lenovo/g505s: enable the webcam [WIP]
+###
+patch -p1 < "./927a79f.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/48424
+### asus/a88xm-e: properly program the IRQ tables
+###
+patch -p1 < "./21d48de.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/48425
+### asus/a88xm-e: update the ACPI routing to match the new IRQ routing
+###
+patch -p1 < "./f001cb1.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/48426
+### asus/a88xm-e: add the PIRQ routing table
+###
+patch -p1 < "./b0beb9b.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/58754
+### asus/am1i-a: fix the IRQs and create the good MP tables
+###
+patch -p1 < "./0a3347f.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/58755
+### asus/am1i-a: update the ACPI routing to match the new IRQ routing
+###
+patch -p1 < "./a223c09.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/58756
+### asus/am1i-a: update the PIRQ routing table
+###
+patch -p1 < "./02cb011.diff"
+###
diff --git a/check_irq_patches.sh b/check_irq_patches.sh
new file mode 100755
index 0000000..0539295
--- /dev/null
+++ b/check_irq_patches.sh
@@ -0,0 +1,21 @@
+#!/bin/sh
+rm -f "./sha256sums_irq_my.txt"
+sha256sum "./8c78f54.diff" >  "./sha256sums_irq_my.txt"
+sha256sum "./f0db861.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./8aa0ae3.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./927a79f.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./21d48de.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./f001cb1.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./b0beb9b.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./0a3347f.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./a223c09.diff" >> "./sha256sums_irq_my.txt"
+sha256sum "./02cb011.diff" >> "./sha256sums_irq_my.txt"
+if cmp -s "./sha256sums_irq_my.txt" "./sha256sums_irq_correct.txt"
+then
+    echo "SHA256 checksums are correct, please run ./apply_irq_patches.sh"
+    exit 0
+else
+    echo "! MISMATCH ! See ./sha256sums_irq_my.txt and ./sha256sums_irq_correct.txt"
+    exit 1
+fi
+#
