From f0db861ede6887f1efa53cebe7c68b11478a2792 Mon Sep 17 00:00:00 2001
From: Mike Banon <mike.banon@3mdeb.com>
Date: Fri, 29 Oct 2021 18:21:37 +0300
Subject: [PATCH] lenovo/g505s: update the ACPI routing to match the new IRQ routing

Update the ACPI routing in accordance with the new IRQ tables.

Signed-off-by: Mike Banon <mikebdp2@gmail.com>
Change-Id: I9ba99cae6ce920cce40126459229a3c7c1ec6310
---

diff --git a/src/mainboard/lenovo/g505s/acpi/routing.asl b/src/mainboard/lenovo/g505s/acpi/routing.asl
index 6f91672..3097e51 100644
--- a/src/mainboard/lenovo/g505s/acpi/routing.asl
+++ b/src/mainboard/lenovo/g505s/acpi/routing.asl
@@ -4,150 +4,158 @@
 	Name(PR0, Package(){
 		/* NB devices */
 		/* Bus 0, Dev 0 - F15 Host Controller */
