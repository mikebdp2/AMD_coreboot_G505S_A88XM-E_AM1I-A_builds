From 0c95d41e26bcfaf464f322a3fbf1022dc0480736 Mon Sep 17 00:00:00 2001
From: Mike Banon <mike.banon@3mdeb.com>
Date: Fri, 29 Oct 2021 12:30:09 +0300
Subject: [PATCH] G505S dGPU support: scripts for applying the unofficial (not-merged-yet) patches

These scripts will help you to securely and conveniently apply three
changes to enable the discrete GPU of AMD-no-PSP Lenovo G505S laptop:
CB:57319, CB:88204, CB:58653 . Save to ./coreboot/ then run
./get_dgpu_patches.sh , ./check_dgpu_patches.sh and ./apply_dgpu_patches.sh

Change-Id: I25e1ec5e8bd32cf32d606e5272a4d0383a57ba81
---

diff --git a/apply_dgpu_patches.sh b/apply_dgpu_patches.sh
new file mode 100755
index 0000000..2eff8ce
--- /dev/null
+++ b/apply_dgpu_patches.sh
@@ -0,0 +1,17 @@
+#!/bin/sh
+###
+### https://review.coreboot.org/c/coreboot/+/57319
+### device/Kconfig: introduce the AMD_DGPU_WITHOUT_EEPROM symbols
+###
+patch -p1 < "./d16d15a.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/88204
+### device/pci: add support for AMD_DGPU_WITHOUT_EEPROM init and OpROM loading
+###
+patch -p1 < "./bac83a5.diff"
+###
+### https://review.coreboot.org/c/coreboot/+/58653
+### lenovo/g505s: enable the AMD_DGPU_WITHOUT_EEPROM discrete VGA adapter
+###
+patch -p1 < "./b69aa70.diff"
+###
diff --git a/check_dgpu_patches.sh b/check_dgpu_patches.sh
new file mode 100755
index 0000000..9459b7f
--- /dev/null
+++ b/check_dgpu_patches.sh
@@ -0,0 +1,14 @@
+#!/bin/sh
+rm -f "./sha256sums_dgpu_my.txt"
+sha256sum "./d16d15a.diff" >  "./sha256sums_dgpu_my.txt"
+sha256sum "./bac83a5.diff" >> "./sha256sums_dgpu_my.txt"
+sha256sum "./b69aa70.diff" >> "./sha256sums_dgpu_my.txt"
+if cmp -s "./sha256sums_dgpu_my.txt" "./sha256sums_dgpu_correct.txt"
+then
+    echo "SHA256 checksums are correct, please run ./apply_dgpu_patches.sh"
+    exit 0
+else
+    echo "! MISMATCH ! See ./sha256sums_dgpu_my.txt and ./sha256sums_dgpu_correct.txt"
+    exit 1
+fi
+#
diff --git a/get_dgpu_patches.sh b/get_dgpu_patches.sh
new file mode 100755
index 0000000..46b9671
--- /dev/null
+++ b/get_dgpu_patches.sh
@@ -0,0 +1,26 @@
+#!/bin/sh
+###
+### https://review.coreboot.org/c/coreboot/+/57319
+### device/Kconfig: introduce the AMD_DGPU_WITHOUT_EEPROM symbols
+###
+rm -f "./d16d15a.diff"
+wget "https://review.coreboot.org/changes/57319/revisions/12/patch?zip"
+unzip "./patch?zip" && rm -f "./patch?zip" # && patch -p1 < "./d16d15a.diff"
+sleep 1
+###
+### https://review.coreboot.org/c/coreboot/+/88204
+### device/pci: add support for AMD_DGPU_WITHOUT_EEPROM init and OpROM loading
+###
+rm -f "./bac83a5.diff"
+wget "https://review.coreboot.org/changes/88204/revisions/1/patch?zip"
+unzip "./patch?zip" && rm -f "./patch?zip" # && patch -p1 < "./bac83a5.diff"
+sleep 1
+###
+### https://review.coreboot.org/c/coreboot/+/58653
+### lenovo/g505s: enable the AMD_DGPU_WITHOUT_EEPROM discrete VGA adapter
+###
+rm -f "./b69aa70.diff"
+wget "https://review.coreboot.org/changes/58653/revisions/5/patch?zip"
+unzip "./patch?zip" && rm -f "./patch?zip" # && patch -p1 < "./b69aa70.diff"
+sleep 1
+###
diff --git a/sha256sums_dgpu_correct.txt b/sha256sums_dgpu_correct.txt
new file mode 100755
index 0000000..1dbaa66
--- /dev/null
+++ b/sha256sums_dgpu_correct.txt
@@ -0,0 +1,3 @@
+d23b1f192eb81ac840c5be6946c8be29c88e1a8b6911f2afc6252b2cf00f8ef1  ./d16d15a.diff
+bed71536d48a32f855b71276c42f06df030917ada84e0e9e64038c28c1ea7edb  ./bac83a5.diff
+d46d3f7768ac040b148f24d9040283c107f96440c1a3d31fa4502c8affa911e1  ./b69aa70.diff
